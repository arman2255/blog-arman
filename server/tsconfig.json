{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",

    "types": ["node"]
  },
  "include": ["src"]
}
