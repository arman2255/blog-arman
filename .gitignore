# ── Dependencies ──────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ── Next.js ───────────────────────────────────
client/.next/
client/out/
client/build/

# ── Server build output ───────────────────────
server/dist/

# ── Environment variables (NEVER commit these) ─
.env
.env.local
.env.development
.env.production
server/.env
client/.env.local
client/.env.example

# ── Uploaded files (user content) ─────────────
server/src/uploads/*
!server/src/uploads/.gitkeep

# ── OS / Editor ───────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/

# ── Logs ──────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── TypeScript ────────────────────────────────
*.tsbuildinfo
client/next-env.d.ts

# ── Kiro IDE ──────────────────────────────────
.kiro/
